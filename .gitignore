# Python 虚拟环境
.venv/
__pycache__/
*.pyc

# dbt 生成产物
target/
dbt_packages/
logs/

# dbt 匿名遥测/用户级文件 (machine-specific, do not commit)
.user.yml

# 敏感配置 (secrets)
.env
*.env

# 本地工具目录
.claude/

# VSCode 本机个人配置:忽略 settings.json(含本机绝对路径),
# 仅提交 settings.json.example 模板(带占位符,克隆后复制并替换路径)
.vscode/settings.json
!.vscode/settings.json.example

# macOS
.DS_Store

# 真实 profiles 放 ~/.dbt/,不入库。
